# ============================================================================
# Snapshot Finance — 환경변수 예시
# 실제 값은 .env (로컬은 .env.development.local) 에 채운다. 이 파일에는 값 금지.
# ============================================================================

# --- Database (PostgreSQL / Supabase) ---
# DATABASE_URL: 앱 런타임 연결 (pooler). DIRECT_URL: 마이그레이션용 direct 연결.
DATABASE_URL=
DIRECT_URL=

# --- Auth (NextAuth v5 / Google OAuth) ---
AUTH_SECRET=
AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- KIS (한국투자증권) Open API ---
# KIS_MODE: prod | vps (모의투자)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_CANO=
KIS_ACNT_PRDT_CD=
KIS_MODE=

# --- AI (Google Generative AI / Gemini) ---
GOOGLE_AI_API_KEY=

# --- 시세 폴백 소스 (선택) ---
# 미설정 시 해당 폴백만 비활성, 앱은 동작.
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=

# --- Rate Limit (Upstash Redis) ---
# 미설정/비-https 시 rate limit·cache 가 fail-open 으로 비활성.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron (pg_cron → API 호출 시 Bearer 토큰) ---
CRON_SECRET=

# --- 일일 포트폴리오 브리핑 엔드포인트 ---
DAILY_BRIEF_TOKEN=
BRIEF_USER_EMAIL=

# --- Supabase Realtime (실시간 시세 broadcast) ---
# ANON_KEY 는 공개 의도값(RLS 보호). SERVICE_ROLE_KEY 는 워커 전용 비공개.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# 커스텀 도메인 사용 시 필수 (미설정 시 OG/sitemap/GSI 콜백이 vercel.app 으로 fallback).
NEXT_PUBLIC_APP_URL=
