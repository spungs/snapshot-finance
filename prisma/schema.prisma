generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  plan               SubscriptionPlan    @default(FREE)
  subscriptionStatus String?             @default("active")
  accounts           SecuritiesAccount[]
  simulations        Simulation[]

  @@map("users")
}

model SecuritiesAccount {
  id                    String              @id @default(cuid())
  userId                String
  accountNumber         String
  accountName           String
  brokerName            String
  apiType               String
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  isAutoSnapshotEnabled Boolean             @default(false)
  snapshots             PortfolioSnapshot[]
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountNumber])
  @@index([userId])
  @@map("securities_accounts")
}

model PortfolioSnapshot {
  id           String            @id @default(cuid())
  accountId    String
  snapshotDate DateTime          @default(now()) @db.Timestamptz(6)
  totalValue   Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  totalProfit  Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  cashBalance  Decimal           @db.Decimal(15, 2)
  note         String?
  createdAt    DateTime          @default(now())
  account      SecuritiesAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  holdings     StockHolding[]

  @@index([accountId, snapshotDate(sort: Desc)])
  @@index([snapshotDate(sort: Desc)])
  @@map("portfolio_snapshots")
}

model StockHolding {
  id           String            @id @default(cuid())
  snapshotId   String
  stockId      String
  quantity     Int
  averagePrice Decimal           @db.Decimal(15, 2)
  currentPrice Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  currentValue Decimal           @db.Decimal(15, 2)
  profit       Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  createdAt    DateTime          @default(now())
  currency     String            @default("KRW")
  purchaseRate Decimal           @default(1) @db.Decimal(10, 2)
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  stock        Stock             @relation(fields: [stockId], references: [id])

  @@index([snapshotId])
  @@index([stockId])
  @@map("stock_holdings")
}

model Stock {
  id          String         @id @default(cuid())
  stockCode   String         @unique
  stockName   String
  market      String
  sector      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  simulations Simulation[]
  histories   StockHistory[]
  holdings    StockHolding[]

  @@index([stockCode])
  @@map("stocks")
}

model StockHistory {
  id         String   @id @default(cuid())
  stockId    String
  date       DateTime @db.Date
  closePrice Decimal  @db.Decimal(15, 4)
  openPrice  Decimal? @db.Decimal(15, 4)
  highPrice  Decimal? @db.Decimal(15, 4)
  lowPrice   Decimal? @db.Decimal(15, 4)
  volume     BigInt?
  currency   String   @default("KRW")
  createdAt  DateTime @default(now())
  stock      Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([date])
  @@map("stock_histories")
}

model Simulation {
  id                String   @id @default(cuid())
  userId            String
  stockId           String
  name              String
  baseDate          DateTime
  quantity          Int
  baseCost          Decimal  @db.Decimal(15, 2)
  currentPrice      Decimal  @db.Decimal(15, 2)
  hypotheticalValue Decimal  @db.Decimal(15, 2)
  actualProfit      Decimal? @db.Decimal(15, 2)
  difference        Decimal  @db.Decimal(15, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  stock             Stock    @relation(fields: [stockId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stockId])
  @@map("simulations")
}

model ApiToken {
  id        String   @id @default(cuid())
  provider  String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_tokens")
}

model KisStockMaster {
  stockCode String   @id
  stockName String
  engName   String?
  market    String
  updatedAt DateTime @updatedAt

  @@index([stockName])
  @@map("kis_stock_masters")
}

enum SubscriptionPlan {
  FREE
  PRO
  MAX
}
