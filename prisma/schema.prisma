generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  emailVerified         DateTime?
  image                 String?
  isAutoSnapshotEnabled Boolean             @default(false)
  cashBalance           Decimal             @default(0) @db.Decimal(15, 2)
  targetAsset           Decimal             @default(0) @db.Decimal(15, 2)
  role                  String              @default("user")
  accounts              Account[]
  holdings              Holding[]
  snapshots             PortfolioSnapshot[]
  deletedAt             DateTime?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PortfolioSnapshot {
  id           String            @id @default(cuid())
  snapshotDate DateTime          @default(now()) @db.Timestamptz(6)
  totalValue   Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  totalProfit  Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  cashBalance  Decimal           @db.Decimal(15, 2)
  note         String?
  createdAt    DateTime          @default(now())
  exchangeRate Decimal           @default(1435) @db.Decimal(10, 2)
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     SnapshotHolding[]

  @@index([userId, snapshotDate(sort: Desc)])
  @@index([snapshotDate(sort: Desc)])
  @@map("portfolio_snapshots")
}

model SnapshotHolding {
  id           String            @id @default(cuid())
  snapshotId   String
  stockId      String
  quantity     Int
  averagePrice Decimal           @db.Decimal(15, 2)
  currentPrice Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  currentValue Decimal           @db.Decimal(15, 2)
  profit       Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  createdAt    DateTime          @default(now())
  currency     String            @default("KRW")
  purchaseRate Decimal           @default(1) @db.Decimal(10, 2)
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  stock        Stock             @relation(fields: [stockId], references: [id])

  @@index([snapshotId])
  @@index([stockId])
  @@map("snapshot_holdings")
}

model Stock {
  id           String            @id @default(cuid())
  stockCode    String            @unique
  stockName    String
  engName      String?           // 영문 종목명
  market       String?
  sector       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  liveHoldings Holding[]
  holdings     SnapshotHolding[]

  @@index([stockCode])
  @@map("stocks")
}

model Holding {
  id             String    @id @default(cuid())
  userId         String
  stockId        String
  quantity       Int
  averagePrice   Decimal   @db.Decimal(15, 2)
  currentPrice   Decimal   @default(0) @db.Decimal(15, 2)
  currency       String    @default("KRW")
  purchaseRate   Decimal   @default(1) @db.Decimal(10, 2)
  priceUpdatedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  stock          Stock     @relation(fields: [stockId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
  @@index([stockId])
  @@map("holdings")
}

model ApiToken {
  id        String   @id @default(cuid())
  provider  String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_tokens")
}

model KisStockMaster {
  stockCode String   @id
  stockName String
  engName   String?
  market    String
  updatedAt DateTime @updatedAt

  @@index([stockName])
  @@index([engName])
  @@map("kis_stock_masters")
}

model CronLog {
  id        String   @id @default(cuid())
  jobName   String
  status    String   // 'SUCCESS', 'FAILED', 'PARTIAL'
  message   String?  @db.Text
  details   Json?    // Store detailed error objects or stats
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("cron_logs")
}

model NewsArticle {
  id          String   @id @default(cuid())
  symbol      String   // e.g., "AAPL"
  title       String
  url         String   @unique
  publishedAt DateTime
  
  // AI Summaries
  summaryShort  String? @db.Text // 3 lines
  summaryMedium String? @db.Text // 5 lines
  summaryLong   String? @db.Text // 10 lines
  
  source      String?
  imageUrl    String?
  
  createdAt   DateTime @default(now())

  @@index([symbol, publishedAt(sort: Desc)])
  @@map("news_articles")
}
