generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  emailVerified         DateTime?
  image                 String?
  isAutoSnapshotEnabled Boolean             @default(false)
  cashBalance           Decimal             @default(0) @db.Decimal(15, 2)
  targetAsset           Decimal             @default(0) @db.Decimal(15, 2)
  accounts              Account[]
  holdings              Holding[]
  snapshots             PortfolioSnapshot[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PortfolioSnapshot {
  id           String            @id @default(cuid())
  snapshotDate DateTime          @default(now()) @db.Timestamptz(6)
  totalValue   Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  totalProfit  Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  cashBalance  Decimal           @db.Decimal(15, 2)
  note         String?
  createdAt    DateTime          @default(now())
  exchangeRate Decimal           @default(1435) @db.Decimal(10, 2)
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     SnapshotHolding[]

  @@index([userId, snapshotDate(sort: Desc)])
  @@index([snapshotDate(sort: Desc)])
  @@map("portfolio_snapshots")
}

model SnapshotHolding {
  id           String            @id @default(cuid())
  snapshotId   String
  stockId      String
  quantity     Int
  averagePrice Decimal           @db.Decimal(15, 2)
  currentPrice Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  currentValue Decimal           @db.Decimal(15, 2)
  profit       Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  createdAt    DateTime          @default(now())
  currency     String            @default("KRW")
  purchaseRate Decimal           @default(1) @db.Decimal(10, 2)
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  stock        Stock             @relation(fields: [stockId], references: [id])

  @@index([snapshotId])
  @@index([stockId])
  @@map("snapshot_holdings")
}

model Stock {
  id           String            @id @default(cuid())
  stockCode    String            @unique
  stockName    String
  market       String
  sector       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  liveHoldings Holding[]
  holdings     SnapshotHolding[]

  @@index([stockCode])
  @@map("stocks")
}

model Holding {
  id             String    @id @default(cuid())
  userId         String
  stockId        String
  quantity       Int
  averagePrice   Decimal   @db.Decimal(15, 2)
  currentPrice   Decimal   @default(0) @db.Decimal(15, 2)
  currency       String    @default("KRW")
  purchaseRate   Decimal   @default(1) @db.Decimal(10, 2)
  priceUpdatedAt DateTime?
  displayOrder   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  stock          Stock     @relation(fields: [stockId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
  @@index([stockId])
  @@index([userId, displayOrder])
  @@map("holdings")
}

model ApiToken {
  id        String   @id @default(cuid())
  provider  String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_tokens")
}

model KisStockMaster {
  stockCode String   @id
  stockName String
  engName   String?
  market    String
  updatedAt DateTime @updatedAt

  @@index([stockName])
  @@map("kis_stock_masters")
}
