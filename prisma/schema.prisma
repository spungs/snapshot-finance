generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  emailVerified         DateTime?
  image                 String?
  isAutoSnapshotEnabled Boolean             @default(false)
  cashBalance           Decimal             @default(0) @db.Decimal(15, 2)
  cashAccounts          Json?
  targetAsset           Decimal             @default(0) @db.Decimal(15, 2)
  role                  String              @default("user")
  agreedAt              DateTime?
  accounts              Account[]
  brokerageAccounts     BrokerageAccount[]
  holdings              Holding[]
  snapshots             PortfolioSnapshot[]
  subscription          Subscription?
  payments              Payment[]
  usageCounters         UsageCounter[]
  deletedAt             DateTime?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PortfolioSnapshot {
  id           String            @id @default(cuid())
  snapshotDate DateTime          @default(now()) @db.Timestamptz(6)
  totalValue   Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  totalProfit  Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  cashBalance  Decimal           @db.Decimal(15, 2)
  cashAccounts Json?
  note         String?
  createdAt    DateTime          @default(now())
  exchangeRate Decimal           @default(1435) @db.Decimal(10, 2)
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     SnapshotHolding[]

  @@index([userId, snapshotDate(sort: Desc)])
  @@index([snapshotDate(sort: Desc)])
  @@map("portfolio_snapshots")
}

model SnapshotHolding {
  id           String            @id @default(cuid())
  snapshotId   String
  stockId      String
  quantity     Int
  averagePrice Decimal           @db.Decimal(15, 2)
  currentPrice Decimal           @db.Decimal(15, 2)
  totalCost    Decimal           @db.Decimal(15, 2)
  currentValue Decimal           @db.Decimal(15, 2)
  profit       Decimal           @db.Decimal(15, 2)
  profitRate   Decimal           @db.Decimal(10, 4)
  createdAt    DateTime          @default(now())
  currency     String            @default("KRW")
  purchaseRate Decimal           @default(1) @db.Decimal(10, 2)
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  stock        Stock             @relation(fields: [stockId], references: [id])

  @@index([snapshotId])
  @@index([stockId])
  @@map("snapshot_holdings")
}

model Stock {
  id           String            @id @default(cuid())
  stockCode    String            @unique
  stockName    String
  engName      String?           // 영문 종목명
  market       String?
  sector       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  liveHoldings Holding[]
  holdings     SnapshotHolding[]

  @@index([stockCode])
  @@map("stocks")
}

model BrokerageAccount {
  id           String    @id @default(cuid())
  userId       String
  name         String
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     Holding[]

  @@index([userId])
  @@map("brokerage_accounts")
}

model Holding {
  id             String           @id @default(cuid())
  userId         String
  accountId      String
  stockId        String
  quantity       Int
  averagePrice   Decimal          @db.Decimal(15, 2)
  currentPrice   Decimal          @default(0) @db.Decimal(15, 2)
  currency       String           @default("KRW")
  purchaseRate   Decimal          @default(1) @db.Decimal(10, 2)
  priceUpdatedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stock          Stock            @relation(fields: [stockId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        BrokerageAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, stockId])
  @@index([userId])
  @@index([accountId])
  @@index([stockId])
  @@map("holdings")
}

model ApiToken {
  id        String   @id @default(cuid())
  provider  String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_tokens")
}

model KisStockMaster {
  stockCode String   @id
  stockName String
  engName   String?
  market    String
  updatedAt DateTime @updatedAt

  @@index([stockName])
  @@index([engName])
  @@map("kis_stock_masters")
}

model KisMasterSyncLog {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now()) @db.Timestamptz(6)
  finishedAt   DateTime? @db.Timestamptz(6)
  status       String    // 'running' | 'success' | 'failed' | 'aborted'
  rowCounts    Json?     // { KOSPI: 2523, KOSDAQ: 1823, NASD: 4967, ... }
  errorMessage String?   @db.Text
  triggeredBy  String    // 'github-actions' | 'manual'

  @@index([startedAt])
  @@index([status])
  @@map("kis_master_sync_logs")
}

model CronLog {
  id        String   @id @default(cuid())
  jobName   String
  status    String   // 'SUCCESS', 'FAILED', 'PARTIAL'
  message   String?  @db.Text
  details   Json?    // Store detailed error objects or stats
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("cron_logs")
}

// 유료 구독 — 사용자당 1개 (FREE/PRO)
model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  plan               String    @default("FREE") // 'FREE' | 'PRO'
  status             String    @default("ACTIVE") // 'ACTIVE' | 'CANCELED' | 'EXPIRED' | 'PAST_DUE'
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  billingKey         String?
  pgProvider         String? // 'PORTONE' | 'TOSS' 등
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments           Payment[]

  @@index([status, currentPeriodEnd]) // 갱신 7일 전 알림 cron 용
  @@map("subscriptions")
}

// 결제 영수증 — PG 트랜잭션 단위, pgTxId 가 멱등키
model Payment {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String?
  amount         Decimal       @db.Decimal(15, 2)
  currency       String        @default("KRW")
  status         String // 'SUCCEEDED' | 'FAILED' | 'REFUNDED' | 'PENDING'
  pgTxId         String?       @unique // PG 트랜잭션 ID, 멱등키
  pgProvider     String?
  paidAt         DateTime?
  refundedAt     DateTime?
  failureReason  String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, paidAt(sort: Desc)])
  @@index([subscriptionId])
  @@map("payments")
}

// 사용량 카운터 — 일/월 단위 quota 추적
model UsageCounter {
  id          String   @id @default(cuid())
  userId      String
  kind        String // 'AI_DAILY' | 'SIMULATION_MONTHLY' 등
  count       Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, periodStart])
  @@index([userId, kind])
  @@map("usage_counters")
}

